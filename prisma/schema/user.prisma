model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  address     String?

  role        Role @default(CUSTOMER)

  status      UserStatus @default(ACTIVE)

  technician  TechnicianProfile?

  bookings    Booking[]

  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("users")
}

