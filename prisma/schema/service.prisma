model Service {

  id              String @id @default(cuid())

  title           String

  description     String

  price           Float

  technicianId    String

  technician       TechnicianProfile @relation(fields:[technicianId], references:[id])

  categoryId      String

  category        Category  @relation(fields:[categoryId], references:[id])
 bookings      Booking[]  

  createdAt DateTime @default(now())
}